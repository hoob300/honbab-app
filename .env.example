# 네이버 지도 API 키 설정
# 네이버 클라우드 플랫폼(https://www.ncloud.com)에서 발급받으세요
# Application > Maps > Web Dynamic Map 사용 신청 후 Client ID를 복사하세요

# 네이버 지도 클라이언트 ID (필수)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID_HERE

# 네이버 로컬 검색 API (선택 - 실제 식당 데이터 연동 시 필요)
# https://developers.naver.com/apps/ 에서 검색 API 신청
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID_HERE
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET_HERE
